#!/usr/bin/env bash
set -euo pipefail

config_dir="$HOME/.config/nix"
token_file="$config_dir/github-access-token.conf"
nix_conf="$config_dir/nix.conf"
include_line="!include $token_file"

if ! command -v gh >/dev/null 2>&1; then
  echo "error: GitHub CLI is not installed. Run the nix-darwin setup first so Homebrew installs gh." >&2
  exit 1
fi

if ! gh auth status --hostname github.com >/dev/null 2>&1; then
  echo "GitHub CLI is not authenticated; starting browser login."
  gh auth login --hostname github.com --git-protocol ssh --web
fi

token="$(gh auth token --hostname github.com)"
if [[ -z "$token" ]]; then
  echo "error: gh did not return a token for github.com." >&2
  exit 1
fi

umask 077
mkdir -p "$config_dir"

tmp="$(mktemp "$config_dir/.github-access-token.conf.XXXXXX")"
trap 'rm -f "$tmp"' EXIT
printf 'access-tokens = github.com=%s\n' "$token" > "$tmp"
chmod 600 "$tmp"
mv "$tmp" "$token_file"
trap - EXIT

touch "$nix_conf"
chmod 600 "$nix_conf"
if ! grep -Fxq "$include_line" "$nix_conf"; then
  if [[ -s "$nix_conf" ]] && [[ "$(tail -c 1 "$nix_conf")" != "" ]]; then
    printf '\n' >> "$nix_conf"
  fi
  printf '# GitHub API token for Nix flakes. Generated by nix-darwin setup.\n%s\n' "$include_line" >> "$nix_conf"
fi

if nix --extra-experimental-features nix-command config show access-tokens 2>/dev/null | grep -q 'github.com='; then
  echo "Installed GitHub token for Nix at $token_file."
  echo "For root-run Nix commands before the next switch, use: sudo env NIX_CONFIG=\"$include_line\" ..."
else
  echo "Installed $token_file, but Nix did not report a GitHub token yet." >&2
  echo "Check $nix_conf for the include line, then try: nix config show access-tokens" >&2
  exit 1
fi
