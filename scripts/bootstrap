#!/usr/bin/env bash
set -euo pipefail

dir="$HOME/.config/nix-darwin"
host="$(scutil --get LocalHostName)"
token_conf="$HOME/.config/nix/github-access-token.conf"

if [[ -z "$host" ]]; then
  echo "error: could not determine LocalHostName (scutil --get LocalHostName)." >&2
  exit 1
fi

# Make Homebrew available even in a fresh, non-login shell.
if [[ -x /opt/homebrew/bin/brew ]]; then
  eval "$(/opt/homebrew/bin/brew shellenv)"
elif [[ -x /usr/local/bin/brew ]]; then
  eval "$(/usr/local/bin/brew shellenv)"
else
  echo "error: Homebrew not found. Install it from https://brew.sh first." >&2
  exit 1
fi

# Create this machine's host entry if it doesn't exist yet.
host_file="$dir/hosts/$host.nix"
if [[ ! -f "$host_file" ]]; then
  mkdir -p "$dir/hosts"
  if [[ "$(uname -m)" == "arm64" ]]; then
    system="aarch64-darwin"
  else
    system="x86_64-darwin"
  fi
  cat > "$host_file" <<EOF
{
  username = "$(id -un)";
  system = "$system";
  # Paths are relative to ./hosts, e.g. workModules = [ ../work/foo.nix ];
  workModules = [ ];
}
EOF
  echo "Created hosts/$host.nix"
fi

# Authenticated GitHub access for Nix flake fetches (avoids API rate limits).
command -v gh >/dev/null 2>&1 || brew install gh
"$dir/scripts/install-github-nix-token"

echo
echo "Make sure you are signed in to the App Store (needed for masApps)."
echo "Running the first switch for host: $host"
echo

# First switch: path: includes the not-yet-committed host file, and NIX_CONFIG
# lets root use the token before /etc/nix/nix.conf has the declarative include.
sudo env NIX_CONFIG="!include $token_conf" \
  nix --extra-experimental-features "nix-command flakes" \
  run github:nix-darwin/nix-darwin#darwin-rebuild -- \
  switch --flake "path:$dir#$host"

# Record the host file now that the build is known to work.
if [[ -n "$(git -C "$dir" status --porcelain -- "hosts/$host.nix")" ]]; then
  git -C "$dir" add "hosts/$host.nix"
  git -C "$dir" commit -m "hosts: add $host"
  echo "Committed hosts/$host.nix — run 'git push' when ready."
fi

echo "Done."
