{
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "command": "bash \"$HOME/.claude/hooks/herdr-agent-state.sh\" session",
            "timeout": 10,
            "type": "command"
          }
        ],
        "matcher": "*"
      }
    ]
  },
  "model": "claude-fable-5[1m]",
  "skipDangerousModePermissionPrompt": true,
  "theme": "dark",
  "tui": "fullscreen"
}
