{
  "hooks": {
    "PermissionRequest": [
      {
        "hooks": [
          {
            "command": "moshi-hook codex-hook",
            "type": "command"
          }
        ]
      }
    ],
    "SessionStart": [
      {
        "hooks": [
          {
            "command": "bash \"$HOME/.codex/herdr-agent-state.sh\" session",
            "timeout": 10,
            "type": "command"
          }
        ]
      },
      {
        "hooks": [
          {
            "command": "moshi-hook codex-hook",
            "type": "command"
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "command": "moshi-hook codex-hook",
            "type": "command"
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "command": "moshi-hook codex-hook",
            "type": "command"
          }
        ]
      }
    ]
  }
}
