#!/bin/sh
# List pending Pi completion markers outside the client's current session.
# Same-session markers are already shown in the tmux window list via
# window-status-format; keeping them out of status-left avoids duplicate alerts.
current_session=$1

tmux list-windows -a -F '#{session_name}	#{window_id}	#{window_index}	#{window_name}	#{@pi_agent_done}' 2>/dev/null |
awk -F '\t' -v current="$current_session" '
  $5 != "" && $1 != current {
    label = $1 ":" $3
    if ($4 != "") {
      label = label ":" $4
    }
    label = label "!"

    # Make each alert independently clickable. tmux exposes the window id in
    # #{mouse_status_range} for range=user clicks; the MouseDown1Status binding
    # in ~/.tmux.conf passes it to tmux-jump-agent-alert.
    item = "#[range=user|" $2 "]" label "#[norange]"

    if (out != "") {
      out = out " "
    }
    out = out item
  }
  END {
    if (out != "") {
      printf "%s", out
    }
  }
'
