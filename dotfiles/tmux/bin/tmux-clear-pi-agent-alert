#!/bin/sh
# Clear Pi's tmux completion marker for the focused/selected window.
# The marker is set by ~/.pi/agent/extensions/tmux-agent-bell.ts on agent_end.

ALERT_OPTION="@pi_agent_done"

target_window=""

# Prefer an explicit tmux window id (@N). Hooks may also pass empty values while
# some contexts expose pane ids (%N), so ignore anything that is not a window id.
for candidate in "$@"; do
  case "$candidate" in
    @*)
      target_window=$candidate
      break
      ;;
  esac
done

if [ -z "$target_window" ]; then
  target_window=$(tmux display-message -p '#{window_id}' 2>/dev/null) || exit 0
fi

case "$target_window" in
  @*) ;;
  *) exit 0 ;;
esac

# Avoid refreshing every client on no-op focus changes.
if [ -z "$(tmux show-options -wqv -t "$target_window" "$ALERT_OPTION" 2>/dev/null)" ]; then
  exit 0
fi

tmux set-window-option -q -t "$target_window" -u "$ALERT_OPTION" 2>/dev/null || exit 0

tmux list-clients -F '#{client_tty}' 2>/dev/null |
while IFS= read -r tmux_client; do
  [ -n "$tmux_client" ] && tmux refresh-client -t "$tmux_client" -S 2>/dev/null || true
done
